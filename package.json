{
  "name": "Multiple Heritage-cardigans",
  "version": "1.0.0",
  "description": "E-commerce platform for Naira Cardigans",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "seed": "node server/seeders/sampleData.js",
    "test": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --config server/jest.config.js --runInBand",
    "test:watch": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --config server/jest.config.js --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test JWT_SECRET=test-secret jest --config server/jest.config.js --runInBand --coverage"
  },
  "keywords": [
    "ecommerce",
    "mern",
    "cardigans"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^10.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
